{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate && next build",
  "git": {
    "deploymentEnabled": {
      "develop": true,
      "main": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/echotik",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/sync-db",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/exchange-rate",
      "schedule": "30 16 * * 1-5"
    }
  ]
}
