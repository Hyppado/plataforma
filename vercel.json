{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate && npx prisma migrate deploy && next build",
  "git": {
    "deploymentEnabled": {
      "develop": true,
      "main": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/echotik",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/hotmart-reconcile",
      "schedule": "0 6 * * *"
    }
  ]
}
