# ─── Banco de Dados (Prisma) ────────────────────────────────────────────────
# Apenas 2 variáveis são necessárias:
#   DATABASE_URL          → pooled connection (runtime, Neon pgbouncer em prod)
#   DATABASE_URL_UNPOOLED → direct connection (migrations, prisma db push, introspection)
#
# Em dev local ambas apontam para o mesmo host.
# Em prod (Neon): DATABASE_URL usa "-pooler" no host, DATABASE_URL_UNPOOLED não.

DATABASE_URL="postgresql://USER@localhost:5432/hyppado"
DATABASE_URL_UNPOOLED="postgresql://USER@localhost:5432/hyppado"

# ─── NextAuth ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Hotmart ────────────────────────────────────────────────────────────────
HOTMART_CLIENTE_ID=""
HOTMART_CLIENT_SECRET=""
HOTMART_BASIC=""
HOTMART_WEBHOOK_SECRET=""
HOTMART_SANDBOX=false

# ─── EchoTik ────────────────────────────────────────────────────────────────
ECHOTIK_BASE_URL="https://open.echotik.live"
ECHOTIK_USERNAME=""
ECHOTIK_PASSWORD=""
# Regions are NOT configured via env var.
# They are managed in the database (Region table) and seeded via prisma/seed.ts.

# ─── Cron ───────────────────────────────────────────────────────────────────
CRON_SECRET="gere-com-openssl-rand-hex-32"

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Transactional emails (onboarding, password setup, password reset).
# Get your API key at https://resend.com — requires verified domain hyppado.com.
RESEND_API_KEY=""

# ─── Vercel Blob Storage ────────────────────────────────────────────────────
# Auto-injected by Vercel when a Blob store is connected.
# Required for image uploads (product covers, creator avatars).
BLOB_READ_WRITE_TOKEN=""
