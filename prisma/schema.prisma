// Prisma schema for Hyppado
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ---------------------------------------------------------------------------
// AUTH / USERS — Domínio 1: Identidade do Sistema
// ---------------------------------------------------------------------------
// O User é a entidade principal e autônoma do sistema.
// Nenhum campo de billing externo (Hotmart ou outro) é obrigatório aqui.
// Vínculos comerciais ficam em ExternalAccountLink (Domínio 2).

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  passwordHash  String?                       // bcrypt hash da senha
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  // LGPD
  lgpdConsentAt      DateTime?                // último consentimento LGPD
  lgpdConsentVersion String?                  // versão do termo aceito
  deletedAt          DateTime?                // soft delete para LGPD (anonimização)

  savedItems    SavedItem[]
  collections   Collection[]
  notes         Note[]
  alerts        Alert[]

  // Subscriptions (generic — origin-agnostic)
  subscriptions     Subscription[]
  auditLogs         AuditLog[]

  // Usage tracking
  usagePeriods      UsagePeriod[]
  usageEvents       UsageEvent[]

  // IAM / access
  accessGrants      AccessGrant[]
  consentRecords    ConsentRecord[]
  erasureRequests   DataErasureRequest[]

  // External account links (Hotmart, future providers)
  externalAccounts  ExternalAccountLink[]
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ---------------------------------------------------------------------------
// PLANS
// ---------------------------------------------------------------------------

model Plan {
  id                  String   @id @default(uuid())
  code                String   @unique  // slug livre: "pro_mensal", "premium_anual", etc.
  name                String             // nome de exibição
  description         String?
  displayPrice        String?            // "R$ 59,90" — texto livre para UI
  priceAmount         Int                // centavos (ex: 5990 = R$ 59,90)
  currency            String   @default("BRL")
  periodicity         PlanPeriod
  isActive            Boolean  @default(true)
  highlight           Boolean  @default(false)  // destaque visual na página de planos
  badge               String?                   // "Mais escolhido", "Novo", etc.
  sortOrder           Int      @default(0)       // ordenação na UI
  features            Json     @default("[]")    // ["40 transcripts / mês", "Suporte prioritário"]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Quotas de uso por plano
  transcriptsPerMonth       Int  @default(40)
  scriptsPerMonth           Int  @default(70)
  insightTokensMonthlyMax   Int  @default(50000)
  scriptTokensMonthlyMax    Int  @default(20000)
  insightMaxOutputTokens    Int  @default(800)
  scriptMaxOutputTokens     Int  @default(1500)

  // Hotmart product/offer mappings (legacy — use PlanExternalMapping for new providers)
  hotmartProductId    String?
  hotmartPlanCode     String?  // hotmart plan_name or code
  hotmartOfferCode    String?  // hotmart offer_code

  subscriptions       Subscription[]
  accessGrants        AccessGrant[]
  externalMappings    PlanExternalMapping[]

  @@index([isActive, sortOrder])
}

enum PlanPeriod {
  MONTHLY
  ANNUAL
}

// ---------------------------------------------------------------------------
// PLAN ↔ EXTERNAL PROVIDER MAPPING
// ---------------------------------------------------------------------------
// Mapeia planos internos a identificadores de provedores externos.
// Permite múltiplos provedores sem poluir a tabela Plan.

model PlanExternalMapping {
  id            String   @id @default(uuid())
  planId        String
  provider      String   // "hotmart", "stripe", etc.
  externalId    String   // productId, priceId, etc.
  externalCode  String?  // planCode, offerCode, etc.
  externalMeta  Json?    // dados extras do provider
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  plan          Plan     @relation(fields: [planId], references: [id])

  @@unique([provider, externalId])
  @@index([planId])
  @@index([provider, isActive])
}

// ---------------------------------------------------------------------------
// COUPONS (sincronizados via Hotmart API)
// ---------------------------------------------------------------------------

model Coupon {
  id                String    @id @default(uuid())
  hotmartCouponCode String    @unique  // código do cupom na Hotmart
  productId         String    // hotmartProductId ("7420891")
  offerCode         String?   // offerCode ao qual o cupom está vinculado
  name              String?
  discountType      String    // PERCENTAGE | FIXED_VALUE
  discountValue     Float     // ex: 20 (20%) ou 50 (R$ 50)
  currency          String    @default("BRL")
  maxUses           Int?      // null = ilimitado
  usedCount         Int       @default(0)
  startsAt          DateTime?
  expiresAt         DateTime?
  isActive          Boolean   @default(true)
  syncedAt          DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([productId])
  @@index([isActive, expiresAt])
}

// ---------------------------------------------------------------------------
// SUBSCRIPTIONS — Origin-agnostic
// ---------------------------------------------------------------------------
// Uma Subscription pertence a um User e referencia um Plan.
// O campo `source` indica a origem (hotmart, manual, invite, etc).
// O detalhamento da origem fica em HotmartSubscription (ou futuro StripeSubscription).

model Subscription {
  id              String             @id @default(uuid())
  userId          String
  planId          String
  status          SubscriptionStatus @default(PENDING)
  source          String             @default("hotmart") // "hotmart" | "manual" | "invite" | "stripe"
  startedAt       DateTime?
  renewedAt       DateTime?
  nextChargeAt    DateTime?
  cancelledAt     DateTime?
  endedAt         DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id])
  plan            Plan               @relation(fields: [planId], references: [id])
  hotmart         HotmartSubscription?
  charges         SubscriptionCharge[]

  @@index([userId])
  @@index([status])
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

// Mapeamento Hotmart → Subscription interna (Domínio 2: dados do provider)
// Esta tabela é específica do Hotmart e não define identidade do usuário.
model HotmartSubscription {
  id                     String    @id @default(uuid())
  subscriptionId         String    @unique
  hotmartSubscriptionId  String    @unique  // subscriber_code da Hotmart
  hotmartProductId       String?
  hotmartPlanCode        String?
  hotmartOfferCode       String?
  buyerEmail             String?
  subscriberCode         String?   @unique
  externalStatus         String?   // status vindo da Hotmart (ACTIVE, CANCELLED, etc.)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  subscription           Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([hotmartProductId])
  @@index([subscriberCode])
}

// Pagamentos/tentativas por assinatura
model SubscriptionCharge {
  id              String       @id @default(uuid())
  subscriptionId  String
  transactionId   String?      @unique // transaction da Hotmart
  amountCents     Int?
  currency        String       @default("BRL")
  status          ChargeStatus @default(PENDING)
  paidAt          DateTime?
  chargeAt        DateTime?
  createdAt       DateTime     @default(now())

  subscription    Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([transactionId])
}

enum ChargeStatus {
  PENDING
  PAID
  REFUNDED
  CANCELLED
  CHARGEBACK
  FAILED
}

// ---------------------------------------------------------------------------
// EXTERNAL ACCOUNT LINKS — Domínio 2: Vínculos Comerciais/Externos
// ---------------------------------------------------------------------------
// Cada registro vincula um User a uma identidade em um provedor externo.
// Um User pode ter 0, 1 ou N vínculos externos.
// Um vínculo pode ser Hotmart, Stripe, ou qualquer futuro provider.
// A existência do User é independente de qualquer vínculo externo.

model ExternalAccountLink {
  id                  String   @id @default(uuid())
  userId              String
  provider            String   // "hotmart", "stripe", etc.
  externalCustomerId  String?  // subscriberCode, stripeCustomerId, etc.
  externalReference   String?  // ucode, buyerRef, etc.
  externalEmail       String?  // email no provedor (pode diferir do email do sistema)
  linkedAt            DateTime @default(now())
  linkConfidence      String   @default("auto_email") // "auto_email" | "manual" | "admin" | "reconciliation"
  linkMethod          String   @default("webhook")    // "webhook" | "sync" | "manual" | "invite"
  isActive            Boolean  @default(true)
  metadata            Json?    // dados extras específicos do provider
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id])

  @@unique([provider, externalCustomerId])
  @@unique([provider, externalEmail])
  @@index([userId])
  @@index([provider, isActive])
}

// ---------------------------------------------------------------------------
// HOTMART WEBHOOK EVENTS
// ---------------------------------------------------------------------------

model HotmartWebhookEvent {
  id                      String              @id @default(uuid())

  // --- Campos extraídos da estrutura v2 da Hotmart ---
  payloadVersion          String?             // "2.0.0"
  eventType               String              // PURCHASE_APPROVED, SUBSCRIPTION_CANCELLATION, etc.
  eventExternalId         String?             // body.id (UUID do evento)

  // Compra
  transactionId           String?             // data.purchase.transaction
  purchaseStatus          String?             // data.purchase.status (APPROVED, CANCELED, etc.)
  isSubscription          Boolean?            // data.purchase.is_subscription
  recurrenceNumber        Int?                // data.purchase.recurrence_number (1=novo, >1=renovação)
  amountCents             Int?                // data.purchase.price.value
  currency                String?             // data.purchase.price.currency_value
  paymentType             String?             // data.purchase.payment.type (CREDIT_CARD, PIX, BILLET)
  offerCode               String?             // data.purchase.offer.code

  // Assinatura
  subscriptionExternalId  String?             // data.subscription.id
  subscriberCode          String?             // data.subscription.subscriber.code
  subscriberEmail         String?             // data.subscription.subscriber.email
  planCode                String?             // data.subscription.plan.name
  planId                  String?             // data.subscription.plan.id
  subscriptionStatus      String?             // data.subscription.status

  // Comprador
  buyerEmail              String?             // data.buyer.email
  buyerName               String?             // data.buyer.name

  // Produto
  productId               String?             // data.product.id
  productName             String?             // data.product.name

  occurredAt              DateTime?           // creation_date (epoch ms convertido)

  // Payload bruto completo
  payloadJson             Json

  // Idempotência: SHA-256(eventType + [subscriptionId|transactionId] + occurredAt)
  idempotencyKey          String              @unique

  // Processamento
  processingStatus        WebhookStatus       @default(RECEIVED)
  receivedAt              DateTime            @default(now())
  processedAt             DateTime?
  errorMessage            String?

  @@index([eventType, receivedAt])
  @@index([subscriberCode])
  @@index([transactionId])
  @@index([buyerEmail])
  @@index([subscriptionExternalId])
}

enum WebhookStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  DUPLICATE
}

// ---------------------------------------------------------------------------
// AUDIT LOG
// ---------------------------------------------------------------------------

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  actorId     String?  // quem fez a ação (admin user_id ou "system")
  action      String   // ex: SUBSCRIPTION_ACTIVATED, PLAN_CHANGED
  entityType  String?  // Subscription, Plan, etc.
  entityId    String?
  before      Json?
  after       Json?
  occurredAt  DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action, occurredAt])
}

// ---------------------------------------------------------------------------
// ACCESS GRANTS (override manual de acesso por admin)
// ---------------------------------------------------------------------------

model AccessGrant {
  id          String    @id @default(uuid())
  userId      String
  grantedBy   String                          // admin user_id
  reason      String                          // motivo do acesso concedido
  planId      String?                         // plano de referência (quotas)
  startsAt    DateTime  @default(now())
  expiresAt   DateTime?                       // null = permanente
  isActive    Boolean   @default(true)
  revokedAt   DateTime?
  revokedBy   String?                         // admin que revogou
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  plan        Plan?     @relation(fields: [planId], references: [id])

  @@index([userId, isActive])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// LGPD — Consent Records (append-only)
// ---------------------------------------------------------------------------

model ConsentRecord {
  id            String   @id @default(uuid())
  userId        String
  consentType   String                         // "terms_of_use", "privacy_policy", "marketing_email"
  version       String                         // versão do documento aceito
  granted       Boolean  @default(true)        // true=consentiu, false=revogou
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())       // imutável (append-only)

  user          User     @relation(fields: [userId], references: [id])

  @@index([userId, consentType])
}

// ---------------------------------------------------------------------------
// LGPD — Data Erasure Requests
// ---------------------------------------------------------------------------

model DataErasureRequest {
  id              String        @id @default(uuid())
  userId          String
  status          ErasureStatus @default(PENDING)
  requestedAt     DateTime      @default(now())
  processedAt     DateTime?
  processedBy     String?                       // admin user_id
  notes           String?
  anonymizedFields Json?                        // campos anonimizados
  createdAt       DateTime      @default(now())

  user            User          @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
}

enum ErasureStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// ---------------------------------------------------------------------------
// INVITATIONS
// ---------------------------------------------------------------------------

model Invitation {
  id          String           @id @default(uuid())
  email       String
  invitedBy   String                              // admin user_id
  planId      String?                              // plano pré-atribuído
  role        UserRole         @default(USER)
  status      InvitationStatus @default(PENDING)
  token       String           @unique             // token seguro para aceitar
  expiresAt   DateTime
  acceptedAt  DateTime?
  userId      String?                              // preenchido quando aceito
  createdAt   DateTime         @default(now())

  @@index([email])
  @@index([token])
  @@index([status])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model SavedItem {
  id         String   @id @default(cuid())
  userId     String
  type       String   // 'video' | 'product'
  externalId String   // ID externo do item
  title      String
  metaJson   Json?    // Additional metadata (thumbnail, creator, etc.)
  createdAt  DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, type, externalId])
  @@index([userId, type])
}

model Collection {
  id        String           @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CollectionItem[]
  
  @@index([userId])
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  type         String     // 'video' | 'product'
  externalId   String
  title        String
  metaJson     Json?
  createdAt    DateTime   @default(now())
  
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  
  @@unique([collectionId, type, externalId])
  @@index([collectionId])
}

model Note {
  id         String   @id @default(cuid())
  userId     String
  type       String   // 'video' | 'product' | 'creator'
  externalId String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, type, externalId])
}

model Alert {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  severity    String   @default("info") // 'info' | 'warning' | 'success'
  type        String   // 'new_product' | 'creator_rise' | 'high_roas' | 'trend'
  payloadJson Json?    // Related data (productId, creatorId, etc.)
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, read])
}

// ---------------------------------------------------------------------------
// USAGE TRACKING
// ---------------------------------------------------------------------------

enum UsageEventType {
  TRANSCRIPT
  SCRIPT
  INSIGHT
}

/// Período de uso mensal por usuário (criado sob demanda na primeira ação do mês)
model UsagePeriod {
  id              String   @id @default(uuid())
  userId          String
  periodStart     DateTime // 1º dia do mês, 00:00:00 UTC
  periodEnd       DateTime // último momento do mês, UTC

  transcriptsUsed Int      @default(0)
  scriptsUsed     Int      @default(0)
  insightsUsed    Int      @default(0)
  tokensUsed      Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  events          UsageEvent[]

  @@unique([userId, periodStart])
  @@index([userId, periodStart])
}

/// Evento atômico de consumo com chave de idempotência
model UsageEvent {
  id             String         @id @default(uuid())
  userId         String
  periodId       String
  type           UsageEventType
  tokensUsed     Int            @default(0)
  refTable       String?        // ex: "Video", "Script"
  refId          String?        // ID do objeto relacionado
  idempotencyKey String         @unique
  occurredAt     DateTime       @default(now())

  user           User           @relation(fields: [userId], references: [id])
  period         UsagePeriod    @relation(fields: [periodId], references: [id])

  @@index([userId, occurredAt])
  @@index([type, occurredAt])
}

// ---------------------------------------------------------------------------
// SETTINGS (configurações dinâmicas via admin)
// ---------------------------------------------------------------------------

model Setting {
  key         String   @id           // ex: "hotmart.product_id", "app.name"
  value       String                 // valor serializado (string)
  label       String?                // rótulo amigável: "ID do Produto Hotmart"
  group       String   @default("general")  // agrupamento na UI: "hotmart", "general"
  type        String   @default("text")     // "text" | "number" | "boolean" | "secret"
  updatedAt   DateTime @updatedAt

  @@index([group])
}

// ---------------------------------------------------------------------------
// ECHOTIK — Categorias & Video Trends (cron ingestão)
// ---------------------------------------------------------------------------

/// Categorias L1 do TikTok Shop sincronizadas via cron EchoTik
model EchotikCategory {
  id                String    @id @default(uuid())
  externalId        String    @unique              // ID vindo da API EchoTik
  name              String
  language          String    @default("en")       // ex: "en", "pt"
  level             Int       @default(1)           // nível na hierarquia (1 = raiz)
  parentExternalId  String?                         // FK lógica para categoria pai
  slug              String?
  extra             Json?                           // campos adicionais da API
  syncedAt          DateTime  @default(now())       // última vez que foi upserted
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([level])
  @@index([language])
}

/// Snapshot diário de métricas de vídeos trending (TikTok Shop)
model EchotikVideoTrendDaily {
  id                String    @id @default(uuid())
  date              DateTime  @db.Date              // dia do snapshot (sem hora)
  rankingCycle      Int       @default(1)            // 1=diário, 2=semanal, 3=mensal
  rankField         Int       @default(2)            // video_rank_field: 1=views, 2=sales
  rankPosition      Int       @default(0)            // posição no ranklist (1-based)
  videoExternalId   String                           // ID do vídeo na plataforma
  title             String?
  authorName        String?
  authorExternalId  String?
  views             BigInt    @default(0)
  likes             BigInt    @default(0)
  comments          BigInt    @default(0)
  favorites         BigInt    @default(0)
  shares            BigInt    @default(0)
  saleCount         BigInt    @default(0)
  gmv               BigInt    @default(0)            // em centavos / menor unidade
  currency          String    @default("USD")
  country           String    @default("US")
  categoryId        String?                          // externalId da categoria
  extra             Json?
  syncedAt          DateTime  @default(now())
  createdAt         DateTime  @default(now())

  @@unique([videoExternalId, date, country, rankingCycle, rankField])
  @@index([date])
  @@index([country, date])
  @@index([country, date, rankingCycle])
  @@index([country, date, rankingCycle, rankField])
  @@index([categoryId, date])
  @@index([rankPosition])
}

/// Snapshot diário de métricas de produtos trending (TikTok Shop)
model EchotikProductTrendDaily {
  id                String    @id @default(uuid())
  date              DateTime  @db.Date
  rankingCycle      Int       @default(1)            // 1=diário, 2=semanal, 3=mensal
  rankField         Int       @default(1)            // product_rank_field: 1=sales, 2=gmv
  rankPosition      Int       @default(0)            // posição no ranklist (1-based)
  productExternalId String                           // product_id da API
  productName       String?
  categoryId        String?                          // L1 category
  categoryL2Id      String?
  categoryL3Id      String?
  minPrice          Float     @default(0)
  maxPrice          Float     @default(0)
  avgPrice          Float     @default(0)            // spu_avg_price
  commissionRate    Float     @default(0)            // product_commission_rate
  saleCount         BigInt    @default(0)            // total_sale_cnt
  gmv               BigInt    @default(0)            // em centavos
  influencerCount   BigInt    @default(0)            // total_ifl_cnt
  videoCount        BigInt    @default(0)            // total_video_cnt
  liveCount         BigInt    @default(0)            // total_live_cnt
  currency          String    @default("USD")
  country           String    @default("US")
  extra             Json?
  syncedAt          DateTime  @default(now())
  createdAt         DateTime  @default(now())

  @@unique([productExternalId, date, country, rankingCycle, rankField])
  @@index([date])
  @@index([country, date])
  @@index([country, date, rankingCycle])
  @@index([country, date, rankingCycle, rankField])
  @@index([categoryId, date])
  @@index([rankPosition])
}

/// Snapshot diário de métricas de criadores/influencers trending (TikTok Shop)
model EchotikCreatorTrendDaily {
  id                String    @id @default(uuid())
  date              DateTime  @db.Date
  rankingCycle      Int       @default(1)            // 1=diário, 2=semanal, 3=mensal
  rankField         Int       @default(2)            // influencer_rank_field: 1=followers, 2=sales
  rankPosition      Int       @default(0)            // posição no ranklist (1-based)
  userExternalId    String                           // user_id da API
  uniqueId          String?                          // @handle do TikTok
  nickName          String?
  avatar            String?
  category          String?                          // categoria principal textual
  ecScore           Float     @default(0)
  followersCount    BigInt    @default(0)
  saleCount         BigInt    @default(0)
  gmv               BigInt    @default(0)            // em centavos
  diggCount         BigInt    @default(0)
  productCount      BigInt    @default(0)
  videoCount        BigInt    @default(0)
  liveCount         BigInt    @default(0)
  mostCategoryId    String?                          // categoria principal ID
  currency          String    @default("USD")
  country           String    @default("US")
  extra             Json?
  syncedAt          DateTime  @default(now())
  createdAt         DateTime  @default(now())

  @@unique([userExternalId, date, country, rankingCycle, rankField])
  @@index([date])
  @@index([country, date])
  @@index([country, date, rankingCycle])
  @@index([country, date, rankingCycle, rankField])
  @@index([rankPosition])
}

/// Cache de detalhes de produto (populado via /api/v3/echotik/product/detail)
/// Usado para enriquecer vídeos com dados do produto associado
model EchotikProductDetail {
  id                String    @id @default(uuid())
  productExternalId String    @unique               // product_id da API
  productName       String?
  coverUrl          String?                          // Primeira imagem extraída do cover_url JSON
  avgPrice          Decimal?  @db.Decimal(12, 2)
  minPrice          Decimal?  @db.Decimal(12, 2)
  maxPrice          Decimal?  @db.Decimal(12, 2)
  rating            Decimal?  @db.Decimal(3, 2)
  commissionRate    Decimal?  @db.Decimal(5, 4)
  categoryId        String?
  region            String?
  extra             Json?                            // Payload completo da API
  fetchedAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([fetchedAt])
}

/// Payload bruto armazenado para reprodutibilidade / debug
model EchotikRawResponse {
  id            String    @id @default(uuid())
  endpoint      String                              // ex: "/categories", "/videos/trending"
  paramsJson    Json?                               // query-params utilizados
  fetchedAt     DateTime  @default(now())
  payloadJson   Json                                // corpo completo da resposta
  payloadHash   String    @unique                   // SHA-256 do payload (dedup)
  ingestionRunId String?

  ingestionRun  IngestionRun? @relation(fields: [ingestionRunId], references: [id])

  @@index([endpoint, fetchedAt])
}

/// Controle de execuções do cron de ingestão
model IngestionRun {
  id            String          @id @default(uuid())
  source        String          @default("echotik")   // identifica a origem
  startedAt     DateTime        @default(now())
  endedAt       DateTime?
  status        IngestionStatus @default(RUNNING)
  statsJson     Json?                                  // { categoriesSynced, videosSynced, ... }
  errorMessage  String?

  rawResponses  EchotikRawResponse[]

  @@index([source, startedAt])
  @@index([status])
}

enum IngestionStatus {
  RUNNING
  SUCCESS
  FAILED
}

/// Regiões/países disponíveis na plataforma
/// Controlado via painel admin — o cron e o seletor de país usam esta tabela
model Region {
  code      String   @id           // "BR", "US", "MX", etc.
  name      String                 // "Brasil", "United States", etc.
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
